{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadWriteCollections",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::jaetill-game-nights/collections/*"
    },
    {
      "Sid": "ReadWriteProfiles",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::jaetill-game-nights/profiles/*"
    },
    {
      "Sid": "ListBucketForExistenceChecks",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::jaetill-game-nights"
    }
  ]
}
