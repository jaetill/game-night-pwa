{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project now subscribes to the ai-team plugin (per ADR-0015). The plugin ships the hook scripts, subagent definitions, and slash commands. This file only carries: (1) the marketplace subscription so the project is self-documenting, (2) the permissions block (plugin settings.json cannot ship permissions per Claude Code's plugin spec).",

  "extraKnownMarketplaces": {
    "agentic-dev-environment": {
      "source": {
        "source": "github",
        "repo": "jaetill/agentic-dev-environment"
      }
    }
  },

  "enabledPlugins": {
    "ai-team@agentic-dev-environment": true
  },

  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo rm*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE*)",
      "Bash(*AWS_SECRET_ACCESS_KEY=*)",
      "Bash(*AWS_SESSION_TOKEN=*)",
      "Bash(*GITHUB_TOKEN=ghp_*)",
      "Bash(*GITHUB_TOKEN=github_pat_*)",
      "Bash(*GITHUB_TOKEN=ghs_*)",
      "Bash(*GITHUB_TOKEN=gho_*)",
      "Bash(*BEGIN PRIVATE KEY*)",
      "Bash(*BEGIN RSA PRIVATE KEY*)",
      "Bash(*BEGIN EC PRIVATE KEY*)",
      "Edit(*.tfstate*)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.ssh/*)",
      "Edit(.aws/credentials)",
      "Edit(.gnupg/*)",
      "Write(*.tfstate*)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(.ssh/*)",
      "Write(.aws/credentials)",
      "Write(.gnupg/*)"
    ]
  }
}
